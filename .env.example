# Copy to .env and fill in real values. Never commit .env.

# --- Database (required) ---
# Local dev: postgres://postgres:postgres@localhost:5432/seatcheck
# Railway: provided automatically by the Postgres plugin
DATABASE_URL="postgres://postgres:postgres@localhost:5432/seatcheck"

# --- Auth (required) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# --- Server ---
PORT=3000
NODE_ENV=development
# Comma-separated list; use "*" only in dev
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"

# --- Background jobs ---
# Set to "true" to enable the nightly NHTSA sync cron in this process.
# (Only one instance should run cron. For Railway, enable on the web service.)
ENABLE_RECALL_CRON=false

# --- NHTSA (optional) ---
# Get a free Socrata app token at https://data.transportation.gov/signup
# Not required — raises your rate limit from throttled to 1,000 req/hr.
SOCRATA_APP_TOKEN=""

# --- Admin ---
# Used to authenticate POST /api/recalls/sync in production.
ADMIN_TOKEN="change-me-admin-token"

# --- Install-check (Claude Vision) ---
# Required for /api/check-install to work. Get one at https://console.anthropic.com
# Without this, /api/check-install returns 503.
ANTHROPIC_API_KEY=""
